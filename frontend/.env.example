# Cloudinary Configuration
# Copy this file to .env and fill in your actual values
# Note: In React, environment variables must be prefixed with REACT_APP_ to be accessible

# Public site URL for profile links / QR (no trailing slash). Required for correct QR in production builds.
# REACT_APP_PUBLIC_SITE_URL=https://your-project.web.app

REACT_APP_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
REACT_APP_CLOUDINARY_API_KEY=your_api_key_here
REACT_APP_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_name_here
